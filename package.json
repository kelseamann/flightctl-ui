{
  "name": "flightctl",
  "version": "0.0.0",
  "description": "Monorepo for flightctl UI",
  "repository": "https://github.com/flightctl/flightctl-ui.git",
  "homepage": "https://github.com/flightctl/flightctl-ui.git",
  "license": "MIT",
  "private": true,
  "workspaces": [
    "./libs/ui-components",
    "./libs/types",
    "./libs/i18n",
    "./apps/ocp-plugin",
    "./apps/standalone"
  ],
  "scripts": {
    "prebuild": "rimraf **/dist",
    "dev": "npm run -w @flightctl/standalone dev",
    "predev:mock": "sh hack/kill-dev-ports.sh",
    "dev:mock": "DEV_MOCK_API=true ENABLE_CLI_ARTIFACTS=false npm run dev",
    "dev:ocp": "npm run -w @flightctl/ocp-plugin dev",
    "dev:kind": "npm run -w @flightctl/standalone dev:kind",
    "build": "npm run -w @flightctl/standalone build",
    "build:pages": "npm run build:libs && ASSET_PATH=${ASSET_PATH:-/rhem-current-state/} IS_RHEM=true npm run build && sh hack/gitlab-pages-prepare.sh",
    "build:ocp": "npm run -w @flightctl/ocp-plugin build",
    "build:libs": "npm run -w @flightctl/types build && npm run -w @flightctl/ui-components build",
    "gen-types": "npm run -w @flightctl/types gen-types",
    "integration-tests:ci": "npm run build:libs && npm run -w @flightctl/standalone start-prod",
    "integration-tests:open": "cd libs/cypress && cypress open --config-file cypress.config.ts",
    "lint": "eslint \"{libs,apps}/*/src/**\" && prettier --check \"{libs,apps}/*/src/**/*.{js,jsx,ts,tsx}\" && npm run i18n",
    "format": "prettier --check --write \"{libs,apps}/*/src/**/*.{js,jsx,ts,tsx}\"",
    "i18n": "npm run -w @flightctl/i18n i18n"
  },
  "devDependencies": {
    "@babel/preset-env": "^7.24.0",
    "@babel/preset-react": "^7.23.3",
    "@babel/preset-typescript": "^7.23.3",
    "@eslint/compat": "^2.0.3",
    "@eslint/eslintrc": "^3.3.5",
    "@eslint/js": "^9.39.4",
    "@typescript-eslint/eslint-plugin": "^8.57.1",
    "@typescript-eslint/parser": "^8.57.1",
    "concurrently": "^8.2.2",
    "cypress": "^15.10.0",
    "eslint": "^9.39.4",
    "eslint-plugin-react": "^7.37.5",
    "eslint-plugin-react-hooks": "^5.2.0",
    "globals": "^17.4.0",
    "i18next-parser": "6.5.0",
    "nodemon": "^3.0.3",
    "prettier": "^3.0.0",
    "rimraf": "^6.x",
    "ts-node": "^10.9.2",
    "typescript": "^5.1.6",
    "webpack-cli": "^5.1.4"
  },
  "dependencies": {
    "fast-json-patch": "^3.1.1",
    "lodash": "^4.18.0"
  }
}
