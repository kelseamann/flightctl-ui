{
  "name": "@flightctl/standalone",
  "version": "0.0.0",
  "description": "Components for Flightctl UI",
  "repository": "https://github.com/flightctl/flightctl-ui.git",
  "homepage": "https://github.com/flightctl/flightctl-ui.git",
  "license": "MIT",
  "private": true,
  "scripts": {
    "prebuild": "tsc --noEmit && rimraf dist",
    "build": "NODE_ENV=production npm run ts-node ../../node_modules/.bin/webpack --mode=production",
    "start-prod": "npm run ts-node ../../node_modules/.bin/webpack serve --mode=production --color --progress",
    "dev": "concurrently \"npm run dev:proxy\" \"npm run dev:ui\"",
    "dev:kind": ". ./scripts/setup_env.sh && npm run dev",
    "dev:proxy": "sh ../../hack/kill-dev-ports.sh 3001 && cd ../../proxy && nodemon --watch 'proxy/**/*' --exec 'go run' app.go --signal SIGKILL",
    "dev:ui": "npm run ts-node ../../node_modules/.bin/webpack serve --mode=development --color --progress",
    "lint": "eslint ./src/ && prettier --check './src/**/*.{tsx,ts}' && npm run i18n",
    "format": "prettier --check --write './src/**/*.{tsx,ts}'",
    "ts-node": "ts-node -O '{\"module\":\"commonjs\"}'"
  },
  "devDependencies": {
    "@types/react-dom": "^18.2.17",
    "copy-webpack-plugin": "^14.0.0",
    "css-loader": "^6.8.1",
    "css-minimizer-webpack-plugin": "^8.0.0",
    "dotenv": "^16.3.1",
    "html-webpack-plugin": "^5.6.3",
    "mini-css-extract-plugin": "^2.10.0",
    "monaco-editor-webpack-plugin": "^7.1.0",
    "postcss": "^8.4.25",
    "raw-loader": "^4.0.2",
    "react-axe": "^3.5.4",
    "style-loader": "^3.3.3",
    "svg-url-loader": "^8.0.0",
    "terser-webpack-plugin": "^5.3.9",
    "ts-loader": "^9.4.4",
    "tsconfig-paths-webpack-plugin": "^4.1.0",
    "url-loader": "^4.1.1",
    "webpack": "^5.105.4",
    "webpack-dev-server": "^5.2.3"
  },
  "dependencies": {
    "@patternfly/patternfly": "^6.4.0",
    "@patternfly/react-charts": "^8.4.0",
    "@patternfly/react-code-editor": "^6.4.0",
    "@patternfly/react-core": "^6.4.0",
    "@patternfly/react-icons": "^6.4.0",
    "@patternfly/react-styles": "^6.4.0",
    "@patternfly/react-table": "^6.4.0",
    "@patternfly/react-log-viewer": "^6.3.0",
    "formik": "^2.4.5",
    "i18next": "^21.8.14",
    "i18next-browser-languagedetector": "^7.2.1",
    "i18next-http-backend": "^2.5.0",
    "js-yaml": "^4.1.1",
    "monaco-editor": "^0.51.0",
    "react": "17.0.1",
    "react-dom": "17.0.1",
    "react-i18next": "^11.7.3",
    "react-router-dom": "^6.30.3",
    "yup": "^1.3.3"
  }
}
